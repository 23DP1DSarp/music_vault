{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://your-backend-domain.com/api/$1"
    },
    {
      "source": "/sanctum/(.*)",
      "destination": "https://your-backend-domain.com/sanctum/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
